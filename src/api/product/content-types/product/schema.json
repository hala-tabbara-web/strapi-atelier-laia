{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Products"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string",
      "required": true
    },
    "Images": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Price": {
      "type": "decimal",
      "required": true
    },
    "SKU": {
      "type": "string"
    },
    "Content": {
      "type": "dynamiczone",
      "components": [
        "text.block",
        "text.composition"
      ]
    },
    "collection": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::collection.collection",
      "inversedBy": "products"
    },
    "metaTitle": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    },
    "faq": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::faq.faq",
      "inversedBy": "products"
    }
  }
}
